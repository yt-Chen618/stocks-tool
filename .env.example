APP_ENV=local
LOG_LEVEL=INFO
EXECUTION_MODE=paper
ALLOW_LIVE_TRADING=false
DEFAULT_BROKER=longbridge
POSTGRES_DB=stocks_tool
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/stocks_tool
REDIS_URL=redis://localhost:6379/0
SQLALCHEMY_ECHO=false
MARKET_EVENT_AUTO_IMPORT_ENABLED=false
MARKET_EVENT_IMPORT_CSV_PATH=
MARKET_EVENT_IMPORT_INTERVAL_SECONDS=3600
MARKET_EVENT_PROVIDER_AUTO_IMPORT_ENABLED=false
MARKET_EVENT_PROVIDER=fmp
MARKET_EVENT_PROVIDER_SYMBOLS=
MARKET_EVENT_PROVIDER_LOOKAHEAD_DAYS=30
MARKET_EVENT_PROVIDER_TIMEOUT_SECONDS=20
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.2
COVERED_CALL_STRATEGY__AUTO_PROPOSE_ENABLED=false
COVERED_CALL_STRATEGY__AUTO_MONITOR_ENABLED=false
COVERED_CALL_STRATEGY__AUTO_LIFECYCLE_ENABLED=false
COVERED_CALL_STRATEGY__PROPOSAL_INTERVAL_SECONDS=3600
COVERED_CALL_STRATEGY__MONITOR_INTERVAL_SECONDS=900
COVERED_CALL_STRATEGY__LIFECYCLE_INTERVAL_SECONDS=300
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
LONGBRIDGE_PAPER_ACCESS_TOKEN=
LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
LONGBRIDGE_LANGUAGE=en
LONGBRIDGE_ENABLE_OVERNIGHT=false
LONGBRIDGE_PRINT_QUOTE_PACKAGES=false
