APP_ENV=local
LOG_LEVEL=INFO
EXECUTION_MODE=paper
ALLOW_LIVE_TRADING=false
DEFAULT_BROKER=longbridge
POSTGRES_DB=stocks_tool
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/stocks_tool
REDIS_URL=redis://localhost:6379/0
SQLALCHEMY_ECHO=false
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
LONGBRIDGE_PAPER_ACCESS_TOKEN=
LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
LONGBRIDGE_LANGUAGE=en
LONGBRIDGE_ENABLE_OVERNIGHT=false
LONGBRIDGE_PRINT_QUOTE_PACKAGES=false
